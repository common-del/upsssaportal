generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  username         String   @unique
  passwordHash     String
  name             String?
  role             String   // SSSA_ADMIN | SCHOOL | VERIFIER | DISTRICT_OFFICIAL
  districtCode     String?
  verifierCapacity Int?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  verifierAssignments VerifierAssignment[]
  verifications       VerificationSubmission[]
  auditLogs           AuditLog[]          @relation("AuditLogActor")
  verifierDistricts   VerifierDistrict[]  @relation("VerifierDistricts")
}

model District {
  id     String   @id @default(cuid())
  code   String   @unique
  nameEn String
  nameHi String
  blocks Block[]
  schools School[]
}

model Block {
  id           String   @id @default(cuid())
  code         String   @unique
  districtCode String
  nameEn       String
  nameHi       String
  district     District @relation(fields: [districtCode], references: [code])
  schools      School[]
}

model School {
  id           String   @id @default(cuid())
  udise        String   @unique
  nameEn       String
  nameHi       String
  category     String   // Primary | Upper Primary | Secondary
  districtCode String
  blockCode    String
  addressEn    String?
  addressHi    String?
  publicPhone  String?
  feesRangeMin Int?
  feesRangeMax Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  district     District       @relation(fields: [districtCode], references: [code])
  block        Block          @relation(fields: [blockCode], references: [code])
  tickets      Ticket[]
  ratings      ParentRating[]
  selfAssessments     SelfAssessmentSubmission[]
  verifierAssignments VerifierAssignment[]
  verifications       VerificationSubmission[]
}

model DisputeCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  nameEn    String
  nameHi    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]
}

model Ticket {
  id              String            @id @default(cuid())
  schoolUdise     String
  categoryCode    String
  districtCode    String            @default("")
  description     String
  submitterName   String?
  submitterMobile String
  status          String            @default("ASSIGNED_TO_SCHOOL")
  handlerLevel    String            @default("SCHOOL") // SCHOOL | BLOCK | DISTRICT | STATE
  nextDueAt       DateTime?
  lastEscalatedAt DateTime?
  resolvedAt      DateTime?
  rejectedAt      DateTime?
  closedReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  school          School            @relation(fields: [schoolUdise], references: [udise])
  category        DisputeCategory   @relation(fields: [categoryCode], references: [code])
  timeline        TicketTimeline[]
}

model TicketTimeline {
  id        String   @id @default(cuid())
  ticketId  String
  actorType String   // PUBLIC | SCHOOL | SYSTEM
  actorRole String?  // SCHOOL | DISTRICT_OFFICIAL | SSSA_ADMIN | SYSTEM
  eventType String   @default("NOTE") // CREATED | SCHOOL_RESPONDED | ESCALATED | RESOLVED | REJECTED | NOTE
  message   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Cycle {
  id         String         @id @default(cuid())
  name       String         @unique
  isActive   Boolean        @default(false)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  ratings             ParentRating[]
  frameworks          Framework[]
  selfAssessments     SelfAssessmentSubmission[]
  verifierAssignments VerifierAssignment[]
  verifications       VerificationSubmission[]
}

model Framework {
  id            String            @id @default(cuid())
  cycleId       String
  status        String            @default("DRAFT") // DRAFT | PUBLISHED
  version       Int               @default(1)
  publishedAt   DateTime?
  publishedBy   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  cycle         Cycle             @relation(fields: [cycleId], references: [id])
  domains       SqaafDomain[]
  subDomains    SubDomain[]
  parameters    Parameter[]
  rubricMappings RubricMapping[]
  levels          FrameworkLevel[]
  gradeBands      GradeBand[]
  selfAssessments SelfAssessmentSubmission[]
  verifications   VerificationSubmission[]

  @@unique([cycleId])
}

model SqaafDomain {
  id            String      @id @default(cuid())
  frameworkId   String
  code          String
  titleEn       String
  titleHi       String
  order         Int
  weightPercent Float?
  isActive      Boolean     @default(true)
  framework     Framework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  subDomains    SubDomain[]

  @@unique([frameworkId, code])
  @@unique([frameworkId, order])
}

model SubDomain {
  id          String      @id @default(cuid())
  frameworkId String
  domainId    String
  code        String
  titleEn     String
  titleHi     String
  order       Int
  isActive    Boolean     @default(true)
  framework   Framework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  domain      SqaafDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  parameters  Parameter[]

  @@unique([frameworkId, code])
  @@unique([domainId, order])
}

model Parameter {
  id               String            @id @default(cuid())
  frameworkId      String
  subDomainId      String
  code             String
  titleEn          String
  titleHi          String
  order            Int
  applicability    Json              // ["PRIMARY","UPPER_PRIMARY","SECONDARY"]
  inputType        String            @default("SINGLE_SELECT")
  evidenceRequired Boolean           @default(false)
  dataSources      Json              @default("[\"Manual\"]")
  isActive         Boolean           @default(true)
  framework        Framework         @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  subDomain        SubDomain         @relation(fields: [subDomainId], references: [id], onDelete: Cascade)
  options          ParameterOption[]
  rubricMappings   RubricMapping[]
  saResponses        SelfAssessmentResponse[]
  verifierResponses  VerificationResponse[]

  @@unique([frameworkId, code])
  @@unique([subDomainId, order])
}

model ParameterOption {
  id          String    @id @default(cuid())
  parameterId String
  key         String    // LEVEL_1, LEVEL_2, LEVEL_3
  labelEn     String
  labelHi     String
  order       Int
  isActive    Boolean   @default(true)
  parameter   Parameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([parameterId, key])
}

model RubricMapping {
  id          String    @id @default(cuid())
  frameworkId String
  parameterId String
  optionKey   String    // LEVEL_1, LEVEL_2, LEVEL_3
  score       Int
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  parameter   Parameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, parameterId, optionKey])
}

model FrameworkLevel {
  id          String    @id @default(cuid())
  frameworkId String
  key         String    // LEVEL_1, LEVEL_2, LEVEL_3
  labelEn     String
  labelHi     String
  order       Int
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, key])
}

model GradeBand {
  id          String    @id @default(cuid())
  frameworkId String
  key         String
  labelEn     String
  labelHi     String
  minPercent  Float
  maxPercent  Float
  order       Int
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, key])
}

model SelfAssessmentSubmission {
  id          String                   @id @default(cuid())
  cycleId     String
  schoolUdise String
  frameworkId String
  status      String                   @default("DRAFT") // DRAFT | SUBMITTED
  startedAt   DateTime?
  submittedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  cycle       Cycle                    @relation(fields: [cycleId], references: [id])
  school      School                   @relation(fields: [schoolUdise], references: [udise])
  framework   Framework                @relation(fields: [frameworkId], references: [id])
  responses   SelfAssessmentResponse[]

  @@unique([cycleId, schoolUdise])
}

model SelfAssessmentResponse {
  id               String                    @id @default(cuid())
  submissionId     String
  parameterId      String
  selectedOptionKey String                   // LEVEL_1 | LEVEL_2 | LEVEL_3
  notes            String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  submission       SelfAssessmentSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  parameter        Parameter                 @relation(fields: [parameterId], references: [id])

  @@unique([submissionId, parameterId])
}

model VerifierAssignment {
  id             String    @id @default(cuid())
  cycleId        String
  schoolUdise    String
  verifierUserId String
  deadlineAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  cycle          Cycle     @relation(fields: [cycleId], references: [id])
  school         School    @relation(fields: [schoolUdise], references: [udise])
  verifier       User      @relation(fields: [verifierUserId], references: [id])
  submission     VerificationSubmission?

  @@unique([cycleId, schoolUdise])
}

model VerificationSubmission {
  id             String                 @id @default(cuid())
  cycleId        String
  schoolUdise    String
  frameworkId    String
  assignmentId   String                 @unique
  verifierUserId String
  status         String                 @default("DRAFT") // DRAFT | SUBMITTED
  startedAt      DateTime?
  submittedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  cycle          Cycle                  @relation(fields: [cycleId], references: [id])
  school         School                 @relation(fields: [schoolUdise], references: [udise])
  framework      Framework              @relation(fields: [frameworkId], references: [id])
  assignment     VerifierAssignment     @relation(fields: [assignmentId], references: [id])
  verifier       User                   @relation(fields: [verifierUserId], references: [id])
  responses      VerificationResponse[]
}

model VerificationResponse {
  id               String                  @id @default(cuid())
  submissionId     String
  parameterId      String
  selectedOptionKey String
  notes            String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  submission       VerificationSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  parameter        Parameter               @relation(fields: [parameterId], references: [id])

  @@unique([submissionId, parameterId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation("AuditLogActor", fields: [actorUserId], references: [id])
}

model VerifierDistrict {
  id             String @id @default(cuid())
  verifierUserId String
  districtCode   String
  verifier       User   @relation("VerifierDistricts", fields: [verifierUserId], references: [id], onDelete: Cascade)

  @@unique([verifierUserId, districtCode])
}

model RatingDimension {
  id        String   @id @default(cuid())
  code      String   @unique
  labelEn   String
  labelHi   String
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentRating {
  id              String   @id @default(cuid())
  cycleId         String
  schoolUdise     String
  submitterMobile String
  ratingsJson     Json     // { TEACHING: 4, INFRA: 3, ... }
  comment         String?
  createdAt       DateTime @default(now())
  cycle           Cycle    @relation(fields: [cycleId], references: [id])
  school          School   @relation(fields: [schoolUdise], references: [udise])

  @@unique([cycleId, schoolUdise, submitterMobile])
}
