generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  role         String   // SSSA_ADMIN | SCHOOL | VERIFIER | DISTRICT_OFFICIAL
  districtCode String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model District {
  id     String   @id @default(cuid())
  code   String   @unique
  nameEn String
  nameHi String
  blocks Block[]
  schools School[]
}

model Block {
  id           String   @id @default(cuid())
  code         String   @unique
  districtCode String
  nameEn       String
  nameHi       String
  district     District @relation(fields: [districtCode], references: [code])
  schools      School[]
}

model School {
  id           String   @id @default(cuid())
  udise        String   @unique
  nameEn       String
  nameHi       String
  category     String   // Primary | Upper Primary | Secondary
  districtCode String
  blockCode    String
  addressEn    String?
  addressHi    String?
  publicPhone  String?
  feesRangeMin Int?
  feesRangeMax Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  district     District       @relation(fields: [districtCode], references: [code])
  block        Block          @relation(fields: [blockCode], references: [code])
  tickets      Ticket[]
  ratings      ParentRating[]
}

model DisputeCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  nameEn    String
  nameHi    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]
}

model Ticket {
  id              String            @id @default(cuid())
  schoolUdise     String
  categoryCode    String
  districtCode    String            @default("")
  description     String
  submitterName   String?
  submitterMobile String
  status          String            @default("ASSIGNED_TO_SCHOOL")
  handlerLevel    String            @default("SCHOOL") // SCHOOL | BLOCK | DISTRICT | STATE
  nextDueAt       DateTime?
  lastEscalatedAt DateTime?
  resolvedAt      DateTime?
  rejectedAt      DateTime?
  closedReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  school          School            @relation(fields: [schoolUdise], references: [udise])
  category        DisputeCategory   @relation(fields: [categoryCode], references: [code])
  timeline        TicketTimeline[]
}

model TicketTimeline {
  id        String   @id @default(cuid())
  ticketId  String
  actorType String   // PUBLIC | SCHOOL | SYSTEM
  actorRole String?  // SCHOOL | DISTRICT_OFFICIAL | SSSA_ADMIN | SYSTEM
  eventType String   @default("NOTE") // CREATED | SCHOOL_RESPONDED | ESCALATED | RESOLVED | REJECTED | NOTE
  message   String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Cycle {
  id        String         @id @default(cuid())
  name      String         @unique
  isActive  Boolean        @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  ratings   ParentRating[]
}

model RatingDimension {
  id        String   @id @default(cuid())
  code      String   @unique
  labelEn   String
  labelHi   String
  isActive  Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentRating {
  id              String   @id @default(cuid())
  cycleId         String
  schoolUdise     String
  submitterMobile String
  ratingsJson     Json     // { TEACHING: 4, INFRA: 3, ... }
  comment         String?
  createdAt       DateTime @default(now())
  cycle           Cycle    @relation(fields: [cycleId], references: [id])
  school          School   @relation(fields: [schoolUdise], references: [udise])

  @@unique([cycleId, schoolUdise, submitterMobile])
}
